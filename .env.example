# Порт сервера
PORT=3000

# Пароль для входа психолога в кабинет (замените!)
ADMIN_PASSWORD=almaty-clinic

# Токен доступа к API кабинета. Если не задан — генерируется при запуске
# и печатается в консоль. Для продакшена задайте свой длинный секрет.
ADMIN_TOKEN=

# Путь к файлу базы данных SQLite
DB_PATH=./screening.db
