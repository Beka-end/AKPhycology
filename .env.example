# --- Кабинет психолога ---
# Пароль для входа в кабинет (замените!)
ADMIN_PASSWORD=almaty-clinic
# Токен доступа к API кабинета. Можно не задавать — тогда он вычисляется
# из пароля. Для продакшена лучше задать свою длинную случайную строку.
ADMIN_TOKEN=

# --- База данных Turso (облачный SQLite) ---
# Обязательно на Vercel / serverless. Получить: см. README (Turso CLI или сайт).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Если переменные Turso не заданы, локально используется файл ./screening.db
# (подходит для разработки и обычного сервера с постоянным диском).

# Порт локального сервера
PORT=3000
