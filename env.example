# --- Учётная запись администратора кабинета ---
# Логин администратора всегда: admin
# ADMIN_PASSWORD — это ПЕРВОНАЧАЛЬНЫЙ пароль admin (создаётся один раз в базе).
# После первого входа пароль можно сменить в кабинете; env его больше не переопределяет.
ADMIN_PASSWORD=almaty-clinic

# Секрет для подписи сессионных токенов (любая длинная случайная строка).
# Если не задан — выводится из ADMIN_PASSWORD. Для продакшена задайте свой.
SESSION_SECRET=

# --- База данных Turso (облачный SQLite, обязательно) ---
# Получить: см. README (Turso CLI или сайт turso.tech).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Порт локального сервера
PORT=3000
